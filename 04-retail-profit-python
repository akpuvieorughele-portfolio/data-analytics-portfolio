DANGER  = '#ef233c'
SUCCESS = '#2ec4b6'


# ------------------------------------------------------------------
# Generate the 9,994-row Superstore dataset (mirrors Tableau sample)
# ------------------------------------------------------------------
np.random.seed(42)
n = 9994

regions    = ['West', 'East', 'Central', 'South']
segments   = ['Consumer', 'Corporate', 'Home Office']
categories = {
    'Furniture':        ['Bookcases', 'Chairs', 'Furnishings', 'Tables'],
    'Office Supplies':  ['Appliances', 'Art', 'Binders', 'Envelopes',
                         'Fasteners', 'Labels', 'Paper', 'Storage', 'Supplies'],
    'Technology':       ['Accessories', 'Copiers', 'Machines', 'Phones']
}

# Weights to replicate realistic Superstore distributions
region_w  = [0.32, 0.29, 0.22, 0.17]
segment_w = [0.52, 0.31, 0.17]

cat_list  = []
sub_list  = []
for cat, subs in categories.items():
    for sub in subs:
        cat_list.append(cat)
        sub_list.append(sub)

sub_w = np.ones(len(sub_list)); sub_w /= sub_w.sum()

idx      = np.random.choice(len(sub_list), size=n, p=sub_w)
cat_col  = [cat_list[i] for i in idx]
sub_col  = [sub_list[i] for i in idx]

# Realistic sales / base cost by category
sales_map   = {'Furniture': (200,1800), 'Office Supplies': (15,400), 'Technology': (100,2500)}
margin_map  = {'Furniture': 0.18, 'Office Supplies': 0.32, 'Technology': 0.28}

sales, discounts, profits = [], [], []
for cat in cat_col:
    lo, hi  = sales_map[cat]
    sale    = round(np.random.uniform(lo, hi), 2)
    disc    = float(np.random.choice([0, 0.10, 0.15, 0.20, 0.30, 0.40, 0.50, 0.70],
                                      p=[0.35, 0.15, 0.12, 0.15, 0.10, 0.07, 0.04, 0.02]))
    base_margin = margin_map[cat]
    # Profit degrades as discount increases; heavy discounts tip negative
    profit = round(sale * (base_margin - disc * 1.6), 2)
    sales.append(sale)
    discounts.append(disc)
    profits.append(profit)

df = pd.DataFrame({
    'Order_ID':      [f'CA-{2021+i//2500}-{100000+i}' for i in range(n)],
    'Order_Date':    pd.date_range('2022-01-01', periods=n, freq='8H'),
    'Region':        np.random.choice(regions,   n, p=region_w),
    'Segment':       np.random.choice(segments,  n, p=segment_w),
    'Category':      cat_col,
    'Sub_Category':  sub_col,
    'Sales':         sales,
    'Discount':      discounts,
    'Profit':        profits,
    'Quantity':      np.random.randint(1, 15, n)
})

df['Profit_Margin'] = (df['Profit'] / df['Sales']).round(4)
df['Year']          = df['Order_Date'].dt.year

# Discount bands
df['Discount_Band'] = pd.cut(
    df['Discount'],
    bins=[-0.001, 0.001, 0.20, 0.30, 1.0],
    labels=['No Discount', '1-20%', '21-30%', '30%+']
)

df.to_csv('data/superstore_transactions.csv', index=False)
print(f'Dataset: {df.shape[0]:,} rows x {df.shape[1]} columns')
df.head()

